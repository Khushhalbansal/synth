# === Server Environment Variables ===
# Copy this file to .env and fill in real values. NEVER commit .env.

# Port for the Express server (Render provides this automatically)
PORT=3001

# Shared bearer token for app ↔ backend auth
API_AUTH_TOKEN=

# Anthropic API key (server-side only, never exposed to client)
ANTHROPIC_API_KEY=

# Google service account credentials (paste the ENTIRE JSON key content as a single line)
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Sheet IDs (from the URL: https://docs.google.com/spreadsheets/d/{THIS_PART}/edit)
TRIATHLON_SHEET_ID=
ROWING_SHEET_ID=
